msgstr "Proszę czekać, trwa generowanie klucza resetowania hasła."

#: ../src/scenes/forgotpassword.rb:60 ../src/scenes/forgotpassword.rb:107
msgctxt "ForgotPassword"
msgid "An unexpected error"
msgstr "Wystąpił nieoczekiwany błąd"

#: ../src/scenes/forgotpassword.rb:62
msgctxt "ForgotPassword"
msgid ""
