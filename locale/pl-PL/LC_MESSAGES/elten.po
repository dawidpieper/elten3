msgid "Enter password reset code"
msgstr "Wprowadź klucz resetowania hasła"

#: ../src/scenes/forgotpassword.rb:30
msgctxt "ForgotPassword"
msgid "Password reset"
msgstr "Reset hasła"

#: ../src/scenes/forgotpassword.rb:50
