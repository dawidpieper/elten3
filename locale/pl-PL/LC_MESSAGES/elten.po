#: ../src/scenes/registration.rb:12
msgctxt "Registration"
msgid ""
"Accounts registrations are not possible with direct code execution, please "
"use an official Elten launcher."
msgstr ""
"Rejestrowanie kont nie jest możliwe podczas bezpośredniego wykonywania kodu. "
"Użyj oficjalnego launchera."

#: ../src/scenes/registration.rb:20
msgctxt "Registration"
msgid ""
"Enter your username. It will be used for identification.The maximum length "
"of the  username is 64 characters"
msgstr ""
"Podaj swój login. Będzie on używany w celu identyfikacji. Maksymalna długość "
"loginu to 64 znaki"

#: ../src/scenes/registration.rb:23
msgctxt "Registration"
msgid "User with this name already exists."
msgstr "Konto o podanym loginie już istnieje."

#: ../src/scenes/registration.rb:34
msgctxt "Registration"
msgid ""
"Enter your password. It is recommended to use a strong password, which "
"consists  of numbers and letters. Maximum length of the password is 256 "
"characters."
msgstr ""
"Podaj swoje hasło. Zalecane jest silne hasło. Hasło takie składa się z liter "
"i cyfr. Długość hasła powinna być krótsza niż dwieście pięćdziesiąt sześć "
"znaków."

#: ../src/scenes/registration.rb:36
msgctxt "Registration"
msgid "Reenter your password"
msgstr "Powtórz hasło"

#: ../src/scenes/registration.rb:39
msgctxt "Registration"
msgid "The entered passwords differ"
msgstr "Podane hasła są różne"

#: ../src/scenes/registration.rb:47
msgctxt "Registration"
msgid ""
"Enter your e-mail address. It will be used in case you forget your password "
"and  to send important information."
msgstr ""
"Podaj swój adres mailowy. Będzie on używany w przypadku zapomnienia hasła i "
"do wysyłania najważniejszych informacji."

#: ../src/scenes/registration.rb:62
msgctxt "Registration"
msgid ""
"Registration is successful, thank you. You can log in using your username "
"and  password."
msgstr ""
"Rejestracja powiodła się, dziękujemy. Możesz teraz się zalogować, używając "
"podanych danych."

#: ../src/scenes/registration.rb:64
msgctxt "Registration"
msgid ""
"Registration is successful, thank you. An activation code has been sent to "
"your e-mail address. You will need to enter it during login."
msgstr ""
"Rejestracja zakończyła się pomyślnie, dziękujemy. Kod aktywacyjny został "
"wysłany na twój adres e-mail. Trzeba będzie go wprowadzić podczas logowania."

#: ../src/scenes/registration.rb:68
msgctxt "Registration"
msgid "Account with the specified username already exists."
msgstr "Konto o podanym loginie już istnieje."

#: ../src/scenes/registration.rb:70
msgctxt "Registration"
msgid "An error occurred while connecting to the server."
msgstr "Wystąpił błąd połączenia z serwerem."

