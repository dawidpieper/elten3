#: ../src/scenes/Update.rb:13
msgctxt "Update"
msgid ""
"A new version of this program is available. Do you want to download and "
"instal it?"
msgstr "Доступно обновление программы. Хотите обновить её сейчас?"

#: ../src/scenes/Update.rb:36 ../src/scenes/Update.rb:66
#: ../src/scenes/Update.rb:68
msgctxt "Update"
msgid "Please wait while files are downloaded."
msgstr "Подождите, пожалуйста. Идёт скачивание."

#: ../src/scenes/Update.rb:40
msgctxt "Update"
msgid ""
"The update has been downloaded. To install it, the program must be "
"restarted.  Press enter to continue or escape to cancel."
msgstr ""
"Обновление загружено. Для его установки необходимо перезапустить программу.  "
"Нажмите enter для продолжения или escape для отмены."

#: ../src/scenes/Update.rb:53
msgctxt "Update"
msgid "Now, the update will be installed. The program will restart."
msgstr "Обновление будет установлено, а программа перезагружена."

#: ../src/scenes/Update.rb:71
msgctxt "Update"
msgid ""
"The program will be now reverted to the latest stable version. Elten will "
"restart.  It may take several minutes."
msgstr ""
"Программа будет возвращена к исходным параметрам, а затем перезапущена. "
"Подождите. Это может занять несколько минут."

